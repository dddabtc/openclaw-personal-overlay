From ad9cc1c43daa0ed99f05e9e7fa4ed70417e2de8f Mon Sep 17 00:00:00 2001
From: zhaod <zhaod@local>
Date: Tue, 3 Mar 2026 22:18:18 -0400
Subject: [PATCH] fix(config): remove sessionPolicies from config schema,
 hardcode defaults

OpenClaw 2026.3.2 removed sessionPolicies from the config schema,
causing 'Unrecognized key' validation errors on upgrade. This patch:

1. Removes sessionPolicies from zod-schema.ts
2. Removes sessionPolicies from types.openclaw.ts
3. Removes sessionPolicies UI hints from schema.ts
4. Hardcodes default policy values in pi-tools.ts

The exec guard logic is unchanged - values are now built-in defaults
rather than user-configurable.
---
 src/agents/pi-tools.ts       | 12 ++++++++++--
 src/config/schema.ts         | 15 ---------------
 src/config/types.openclaw.ts | 11 -----------
 src/config/zod-schema.ts     | 20 --------------------
 4 files changed, 10 insertions(+), 48 deletions(-)

diff --git a/src/agents/pi-tools.ts b/src/agents/pi-tools.ts
index 9d1110013..cbe6546e9 100644
--- a/src/agents/pi-tools.ts
+++ b/src/agents/pi-tools.ts
@@ -146,8 +146,16 @@ function resolveExecConfig(params: { cfg?: OpenClawConfig; agentId?: string }) {
     notifyOnExitEmptySuccess:
       agentExec?.notifyOnExitEmptySuccess ?? globalExec?.notifyOnExitEmptySuccess,
     applyPatch: agentExec?.applyPatch ?? globalExec?.applyPatch,
-    mainSessionPolicy: cfg?.sessionPolicies?.main,
-    sessionPolicies: cfg?.sessionPolicies,
+    mainSessionPolicy: {
+      forbidLongExec: true,
+      requireBackgroundForExec: true,
+      maxExecTimeoutSec: 120,
+      maxOutputBytes: 102_400,
+    },
+    sessionPolicies: {
+      main: { forbidLongExec: true, requireBackgroundForExec: true, maxExecTimeoutSec: 120, maxOutputBytes: 102_400 },
+      subagent: { maxOutputBytes: 0 },
+    },
   };
 }
 
