From a37d4949b572593f015980d818572be14eb3f13a Mon Sep 17 00:00:00 2001
From: subagent-bot <subagent-bot@example.com>
Date: Sun, 8 Mar 2026 06:27:31 -0300
Subject: [PATCH 8/8] feat(subagent): default runTimeoutSeconds to 6h

---
 src/agents/subagent-spawn.ts       | 5 ++---
 src/config/types.agent-defaults.ts | 2 +-
 2 files changed, 3 insertions(+), 4 deletions(-)

diff --git a/src/agents/subagent-spawn.ts b/src/agents/subagent-spawn.ts
index 8f7c41866..2a346d79a 100644
--- a/src/agents/subagent-spawn.ts
+++ b/src/agents/subagent-spawn.ts
@@ -283,13 +283,12 @@ export async function spawnSubagentDirect(
   const cfg = loadConfig();
 
   // When agent omits runTimeoutSeconds, use the config default.
-  // Falls back to 0 (no timeout) if config key is also unset,
-  // preserving current behavior for existing deployments.
+  // Falls back to 21600 (6h) if config key is unset.
   const cfgSubagentTimeout =
     typeof cfg?.agents?.defaults?.subagents?.runTimeoutSeconds === "number" &&
     Number.isFinite(cfg.agents.defaults.subagents.runTimeoutSeconds)
       ? Math.max(0, Math.floor(cfg.agents.defaults.subagents.runTimeoutSeconds))
-      : 0;
+      : 21_600;
   const runTimeoutSeconds =
     typeof params.runTimeoutSeconds === "number" && Number.isFinite(params.runTimeoutSeconds)
       ? Math.max(0, Math.floor(params.runTimeoutSeconds))
diff --git a/src/config/types.agent-defaults.ts b/src/config/types.agent-defaults.ts
index a242d0bbc..9acafd332 100644
--- a/src/config/types.agent-defaults.ts
+++ b/src/config/types.agent-defaults.ts
@@ -277,7 +277,7 @@ export type AgentDefaultsConfig = {
     model?: AgentModelConfig;
     /** Default thinking level for spawned sub-agents (e.g. "off", "low", "medium", "high"). */
     thinking?: string;
-    /** Default run timeout in seconds for spawned sub-agents (0 = no timeout). */
+    /** Default run timeout in seconds for spawned sub-agents (default: 21600 = 6h; 0 = no timeout). */
     runTimeoutSeconds?: number;
     /** Gateway timeout in ms for sub-agent announce delivery calls (default: 60000). */
     announceTimeoutMs?: number;
-- 
