+const STRICT_CONTROL_COMMAND_RE = /^\/(stop|status)(?:@[\w_]+)?$/i;
+
+function matchStrictControlCommand(ctx: FinalizedMsgContext): "stop" | "status" | null {
+  const raw =
+    (typeof ctx.CommandBody === "string" && ctx.CommandBody.trim()) ||
+    (typeof ctx.BodyForCommands === "string" && ctx.BodyForCommands.trim()) ||
+    (typeof ctx.RawBody === "string" && ctx.RawBody.trim()) ||
+    (typeof ctx.Body === "string" && ctx.Body.trim()) ||
+    "";
+  if (!raw) {
+    return null;
+  }
+  const matched = raw.match(STRICT_CONTROL_COMMAND_RE);
+  if (!matched?.[1]) {
+    return null;
+  }
+  const command = matched[1].toLowerCase();
+  return command === "stop" || command === "status" ? command : null;
+}
+
 const resolveSessionStoreLookup = (
   ctx: FinalizedMsgContext,
   cfg: OpenClawConfig,
@@ -271,9 +292,60 @@ export async function dispatchReplyFromConfig(params: {
