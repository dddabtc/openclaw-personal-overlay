+function resolveSessionMaxOutputBytes(params: {
+  sessionPolicies?: ExecSessionPolicies;
+  mainSessionPolicy?: ExecMainSessionPolicy;
+  sessionKey?: string;
+}) {
+  const parsed = parseAgentSessionKey(params.sessionKey);
+  const rest = (parsed?.rest ?? "").toLowerCase();
+  const isSubagent = rest.startsWith("subagent:");
+  const raw = isSubagent
+    ? params.sessionPolicies?.subagent?.maxOutputBytes
+    : params.mainSessionPolicy?.maxOutputBytes ?? params.sessionPolicies?.main?.maxOutputBytes;
+  const fallback = isSubagent ? 0 : 102_400;
+  if (typeof raw !== "number" || !Number.isFinite(raw) || raw < 0) {
+    return fallback;
+  }
+  return Math.floor(raw);
+}
+
+function applyMaxOutputBytes(text: string, maxBytes: number): string {
+  if (maxBytes <= 0) {
+    return text;
+  }
+  const source = String(text ?? "");
+  const size = Buffer.byteLength(source, "utf8");
+  if (size <= maxBytes) {
+    return source;
+  }
+  const suffix = `\n…(truncated, ${size} bytes → ${maxBytes} bytes. Use sub-agent for full output.)`;
+  const budget = Math.max(0, maxBytes - Buffer.byteLength(suffix, "utf8"));
+  let low = 0;
+  let high = source.length;
+  while (low < high) {
+    const mid = Math.ceil((low + high) / 2);
+    const candidate = source.slice(0, mid);
+    if (Buffer.byteLength(candidate, "utf8") <= budget) {
+      low = mid;
+    } else {
+      high = mid - 1;
+    }
+  }
+  return `${source.slice(0, low)}${suffix}`;
+}
+
 export function createExecTool(
