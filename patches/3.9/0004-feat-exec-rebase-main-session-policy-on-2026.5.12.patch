+const PERSONAL_MAIN_SESSION_POLICY_DEFAULTS: Required<
+  Pick<
+    ExecMainSessionPolicy,
+    "forbidLongExec" | "requireBackgroundForExec" | "blockSshCommands" | "maxOutputBytes"
+  >
+> & { maxExecTimeoutSec: number } = {
+  forbidLongExec: true,
+  requireBackgroundForExec: false,
+  maxExecTimeoutSec: 120,
+  blockSshCommands: true,
+  maxOutputBytes: 51_200,
+};
+
+function isMainAgentSession(sessionKey?: string): boolean {
+  if (!sessionKey) {
+    return false;
+  }
+  return sessionKey.trim() === "agent:main:main";
+}
+
+function resolveMainSessionPolicy(
+  policy?: ExecMainSessionPolicy,
+): typeof PERSONAL_MAIN_SESSION_POLICY_DEFAULTS {
+  return {
+    forbidLongExec: policy?.forbidLongExec ?? PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.forbidLongExec,
+    requireBackgroundForExec:
+      policy?.requireBackgroundForExec ??
+      PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.requireBackgroundForExec,
+    maxExecTimeoutSec:
+      typeof policy?.maxExecTimeoutSec === "number" && Number.isFinite(policy.maxExecTimeoutSec)
+        ? Math.max(1, Math.trunc(policy.maxExecTimeoutSec))
+        : PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.maxExecTimeoutSec,
+    blockSshCommands:
+      policy?.blockSshCommands ?? PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.blockSshCommands,
+    maxOutputBytes:
+      typeof policy?.maxOutputBytes === "number" && Number.isFinite(policy.maxOutputBytes)
+        ? Math.max(1, Math.trunc(policy.maxOutputBytes))
+        : PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.maxOutputBytes,
+  };
+}
+
+function looksLikeSshCommand(command: string): boolean {
+  const normalized = command.trim().toLowerCase();
+  return (
+    /(^|[;&|(])\s*(ssh|scp|sftp)\b/.test(normalized) ||
+    /\brsync\b[^\n]*\b-e\s+ssh\b/.test(normalized)
+  );
+}
+
+function enforceMainSessionExecPolicy(params: {
+  sessionKey?: string;
+  policy?: ExecMainSessionPolicy;
+  command: string;
+  timeout?: number;
+  backgroundRequested: boolean;
+}): { policy: typeof PERSONAL_MAIN_SESSION_POLICY_DEFAULTS; isMainSession: boolean } {
+  const isMainSession = isMainAgentSession(params.sessionKey);
+  const policy = resolveMainSessionPolicy(params.policy);
+  if (!isMainSession) {
+    return { policy, isMainSession };
+  }
+  if (policy.blockSshCommands && looksLikeSshCommand(params.command)) {
+    throw new Error(
+      "Main session policy blocked SSH command. Use a delegated/background path instead.",
+    );
+  }
+  const timeoutSec =
+    typeof params.timeout === "number" && Number.isFinite(params.timeout)
+      ? Math.max(1, Math.trunc(params.timeout))
+      : policy.maxExecTimeoutSec;
+  if (policy.forbidLongExec && timeoutSec > policy.maxExecTimeoutSec) {
+    throw new Error(
+      `Main session policy blocked exec: foreground timeout ${timeoutSec}s exceeds ${policy.maxExecTimeoutSec}s. Use background=true/yieldMs or a subagent.`,
+    );
+  }
+  if (policy.requireBackgroundForExec && !params.backgroundRequested) {
+    throw new Error(
+      "Main session policy blocked exec: background=true is required in the main session.",
+    );
+  }
+  return { policy, isMainSession };
+}
+
 function rejectUnsafeControlShellCommand(command: string): void {
   const rawCommand = command.trim();
   const analysis = analyzeShellCommand({ command: rawCommand });
