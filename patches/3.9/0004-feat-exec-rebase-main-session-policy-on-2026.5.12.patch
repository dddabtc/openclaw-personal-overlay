@@ -0,0 +1,35 @@
+import { describe, expect, it } from "vitest";
+import { createExecTool } from "./bash-tools.exec.js";
+
+const createMainSessionExecTool = () =>
+  createExecTool({
+    sessionKey: "agent:main:main",
+    security: "full",
+    ask: "off",
+  });
+
+describe("main-session exec defaults", () => {
+  it("blocks long foreground exec without policy config", async () => {
+    const tool = createMainSessionExecTool();
+    await expect(
+      tool.execute("call", { command: "echo hello", timeout: 999 }, undefined),
+    ).rejects.toThrow(/Main session policy blocked exec/);
+  });
+
+  it("blocks ssh command without policy config", async () => {
+    const tool = createMainSessionExecTool();
+    await expect(
+      tool.execute("call", { command: "ssh user@example.com", timeout: 10 }, undefined),
+    ).rejects.toThrow(/blocked SSH command/);
+  });
+
+  it("allows short safe foreground exec", async () => {
+    const tool = createMainSessionExecTool();
+    const res = await tool.execute(
+      "call",
+      { command: "echo ok", timeout: 10, yieldMs: 1000 },
+      undefined,
+    );
+    expect(String((res.details as { aggregated?: string }).aggregated ?? "")).toContain("ok");
+  });
+});
