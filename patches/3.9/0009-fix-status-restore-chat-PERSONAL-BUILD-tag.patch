   const costLine = costLabel ? `💵 Cost: ${costLabel}` : null;
@@ -973,6 +978,7 @@ export function buildStatusMessage(args: StatusArgs): string {
 
   return [
     versionLine,
+    personalBuildLine,
     args.timeLine,
     args.uptimeLine,
     ...modelLines,
