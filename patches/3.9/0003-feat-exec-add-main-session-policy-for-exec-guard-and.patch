From 6dec89eeec4593dad7ddb302c327fb269c5b05f7 Mon Sep 17 00:00:00 2001
From: dda <dddabtc@users.noreply.github.com>
Date: Tue, 31 Mar 2026 22:26:22 -0300
Subject: [PATCH] feat(exec): add main session policy for exec guard and SSH
 block

---
 src/agents/bash-tools.exec-types.ts | 19 +++++++++++++++++++
 1 file changed, 19 insertions(+)

diff --git a/src/agents/bash-tools.exec-types.ts b/src/agents/bash-tools.exec-types.ts
index e834457f1..ebe7f4d95 100644
--- a/src/agents/bash-tools.exec-types.ts
+++ b/src/agents/bash-tools.exec-types.ts
@@ -1,5 +1,22 @@
 import type { ExecApprovalDecision } from "../infra/exec-approvals.js";
 import type { ExecAsk, ExecHost, ExecSecurity, ExecTarget } from "../infra/exec-approvals.js";
+
+/**
+ * PERSONAL BUILD: Main session execution policy.
+ * Controls restrictions on exec commands in the main agent session.
+ */
+export type ExecMainSessionPolicy = {
+  /** Block long-running foreground commands in main session. */
+  forbidLongExec?: boolean;
+  /** Require background=true for all exec in main session. */
+  requireBackgroundForExec?: boolean;
+  /** Maximum allowed timeout (seconds) for foreground exec in main session. */
+  maxExecTimeoutSec?: number;
+  /** Block SSH-related commands (ssh, scp, sftp, rsync over ssh). */
+  blockSshCommands?: boolean;
+  /** Maximum output bytes for main session (default: 50KB = 51200). */
+  maxOutputBytes?: number;
+};
 import type { SafeBinProfileFixture } from "../infra/exec-safe-bin-policy.js";
 import type { BashSandboxConfig } from "./bash-tools.shared.js";
 import type { EmbeddedFullAccessBlockedReason } from "./pi-embedded-runner/types.js";
@@ -31,6 +48,8 @@ export type ExecToolDefaults = {
   accountId?: string;
   notifyOnExit?: boolean;
   notifyOnExitEmptySuccess?: boolean;
+  /** PERSONAL BUILD: Main session execution policy. */
+  mainSessionPolicy?: ExecMainSessionPolicy;
   cwd?: string;
 };
 
-- 
