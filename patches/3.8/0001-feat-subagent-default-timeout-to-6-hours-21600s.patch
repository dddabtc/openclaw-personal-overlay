From 32e3e0b13688a88abbf2e9ba60ef59c1ae8ad30 Mon Sep 17 00:00:00 2001
From: subagent-bot <subagent-bot@example.com>
Date: Sun, 8 Mar 2026 08:13:03 -0300
Subject: [PATCH] feat(subagent): default timeout to 6 hours (21600s)

diff --git a/src/agents/subagent-spawn-plan.ts b/src/agents/subagent-spawn-plan.ts
index 4ee911aab..2dfd0447f 100644
--- a/src/agents/subagent-spawn-plan.ts
+++ b/src/agents/subagent-spawn-plan.ts
@@ -30,7 +30,7 @@ export function resolveConfiguredSubagentRunTimeoutSeconds(params: {
     typeof params.cfg?.agents?.defaults?.subagents?.runTimeoutSeconds === "number" &&
     Number.isFinite(params.cfg.agents.defaults.subagents.runTimeoutSeconds)
       ? Math.max(0, Math.floor(params.cfg.agents.defaults.subagents.runTimeoutSeconds))
-      : 0;
+      : 21600;
   return typeof params.runTimeoutSeconds === "number" && Number.isFinite(params.runTimeoutSeconds)
     ? Math.max(0, Math.floor(params.runTimeoutSeconds))
     : cfgSubagentTimeout;
