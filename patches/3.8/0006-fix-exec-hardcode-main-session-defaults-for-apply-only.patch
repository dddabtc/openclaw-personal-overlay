+const PERSONAL_MAIN_SESSION_POLICY_DEFAULTS: Required<
+  Pick<ExecMainSessionPolicy, "forbidLongExec" | "requireBackgroundForExec" | "blockSshCommands" | "maxOutputBytes">
+> & { maxExecTimeoutSec: number } = {
+  forbidLongExec: true,
+  requireBackgroundForExec: true,
+  maxExecTimeoutSec: 120,
+  blockSshCommands: true,
+  maxOutputBytes: 51_200,
+};
+
+/**
+ * Check if the session key indicates a main agent session (not a subagent).
+ */
+function isMainAgentSession(sessionKey?: string): boolean {
+  const parsed = parseAgentSessionKey(sessionKey);
+  if (!parsed) {
+    const key = (sessionKey ?? "").trim().toLowerCase();
+    return key === "main" || key.endsWith(":main");
+  }
+  return !parsed.rest.includes("subagent:");
+}
+
+/**
+ * Resolve the effective main session policy, applying hardcoded defaults.
+ */
+function resolveMainSessionPolicy(policy?: ExecMainSessionPolicy): Required<ExecMainSessionPolicy> {
+  return {
+    forbidLongExec: policy?.forbidLongExec ?? PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.forbidLongExec,
+    requireBackgroundForExec:
+      policy?.requireBackgroundForExec ??
+      PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.requireBackgroundForExec,
+    maxExecTimeoutSec:
+      typeof policy?.maxExecTimeoutSec === "number" &&
+      Number.isFinite(policy.maxExecTimeoutSec) &&
+      policy.maxExecTimeoutSec > 0
+        ? Math.floor(policy.maxExecTimeoutSec)
+        : PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.maxExecTimeoutSec,
+    blockSshCommands: policy?.blockSshCommands ?? PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.blockSshCommands,
+    maxOutputBytes:
+      typeof policy?.maxOutputBytes === "number" && Number.isFinite(policy.maxOutputBytes)
+        ? Math.max(0, Math.floor(policy.maxOutputBytes))
+        : PERSONAL_MAIN_SESSION_POLICY_DEFAULTS.maxOutputBytes,
+  };
+}
+
+const SSH_COMMAND_PATTERNS = [
+  /^\s*ssh\b/i,
+  /^\s*scp\b/i,
+  /^\s*sftp\b/i,
+  /^\s*rsync\s+.*-e\s+['"]?ssh/i,
+  /^\s*rsync\s+.*--rsh\s*=\s*['"]?ssh/i,
+  /^\s*rsync\s+[^/]*:/i,
+];
+
+function isSshCommand(command: string): boolean {
+  return SSH_COMMAND_PATTERNS.some((pattern) => pattern.test(command));
+}
+
+function enforceMainSessionPolicy(params: {
+  command: string;
+  sessionKey?: string;
+  policy?: ExecMainSessionPolicy;
+  timeout?: number;
+  background?: boolean;
+  yieldMs?: number;
+}): void {
+  const { command, sessionKey, policy, timeout, background, yieldMs } = params;
+  if (!isMainAgentSession(sessionKey)) {
+    return;
+  }
+
+  const effectivePolicy = resolveMainSessionPolicy(policy);
+
+  if (effectivePolicy.blockSshCommands && isSshCommand(command)) {
+    throw new Error(
+      [
+        "Main session policy blocked SSH command.",
+        "SSH/SCP/SFTP commands must be executed through a sub-session.",
+        "Use sessions_spawn to run this command in an isolated session.",
+      ].join("\\n"),
+    );
+  }
+
+  if (effectivePolicy.forbidLongExec) {
+    const maxExecTimeoutSec = effectivePolicy.maxExecTimeoutSec;
+    const backgroundRequested = background === true;
+    const yieldRequested = typeof yieldMs === "number";
+    const yieldExceedsLimit = !yieldRequested || yieldMs > 120_000;
+    const timeoutMissingOrTooLarge =
+      timeout === undefined || timeout <= 0 || timeout > maxExecTimeoutSec;
+
+    const longExecByTimeout = timeoutMissingOrTooLarge;
+    const longExecByForeground =
+      !backgroundRequested && (effectivePolicy.requireBackgroundForExec || yieldExceedsLimit);
+
+    if (longExecByTimeout || longExecByForeground) {
+      throw new Error(
+        [
+          `Main session policy blocked exec: command appears long-running.`,
+          `For main session, timeout must be <= ${maxExecTimeoutSec}s and long runs must use background=true.`,
+          "Use sessions_spawn for longer tasks, or set background=true with an appropriate timeout.",
+        ].join("\\n"),
+      );
+    }
+  }
+}
+
 type ParsedExecApprovalCommand = {
   approvalId: string;
   decision: "allow-once" | "allow-always" | "deny";
@@ -508,8 +617,27 @@ export function createExecTool(
         throw new Error("Provide a command to start.");
       }
 
-      const maxOutput = DEFAULT_MAX_OUTPUT;
-      const pendingMaxOutput = DEFAULT_PENDING_MAX_OUTPUT;
+      enforceMainSessionPolicy({
+        command: params.command,
+        sessionKey: defaults?.sessionKey,
+        policy: defaults?.mainSessionPolicy,
+        timeout: params.timeout,
+        background: params.background,
+        yieldMs: params.yieldMs,
+      });
+
+      const effectiveMainPolicy = isMainAgentSession(defaults?.sessionKey)
+        ? resolveMainSessionPolicy(defaults?.mainSessionPolicy)
+        : undefined;
+      const policyMaxOutput = effectiveMainPolicy?.maxOutputBytes;
+      const mainSessionOutputCap =
+        typeof policyMaxOutput === "number" && policyMaxOutput > 0 ? policyMaxOutput : undefined;
+      const maxOutput = mainSessionOutputCap
+        ? Math.min(DEFAULT_MAX_OUTPUT, mainSessionOutputCap)
+        : DEFAULT_MAX_OUTPUT;
+      const pendingMaxOutput = mainSessionOutputCap
+        ? Math.min(DEFAULT_PENDING_MAX_OUTPUT, mainSessionOutputCap)
+        : DEFAULT_PENDING_MAX_OUTPUT;
       const warnings: string[] = [];
       let execCommandOverride: string | undefined;
       const backgroundRequested = params.background === true;
