Subject: [PATCH] fix(exec): hardcode main-session policy defaults for
 apply-only behavior

---
 ...h-tools.exec.main-session-defaults.test.ts |  31 ++++
 src/agents/bash-tools.exec.ts                 | 132 +++++++++++++++++-
 2 files changed, 161 insertions(+), 2 deletions(-)
 create mode 100644 src/agents/bash-tools.exec.main-session-defaults.test.ts

diff --git a/src/agents/bash-tools.exec.main-session-defaults.test.ts b/src/agents/bash-tools.exec.main-session-defaults.test.ts
new file mode 100644
index 000000000..1c9003e19
--- /dev/null
+++ b/src/agents/bash-tools.exec.main-session-defaults.test.ts
@@ -0,0 +1,31 @@
+import { describe, expect, it } from "vitest";
+import { createExecTool } from "./bash-tools.exec.js";
+
+const createMainSessionExecTool = () =>
+  createExecTool({
+    sessionKey: "agent:main:main",
+    security: "full",
+    ask: "off",
+  });
+
+describe("main-session exec defaults", () => {
+  it("blocks long foreground exec without policy config", async () => {
+    const tool = createMainSessionExecTool();
+    await expect(
+      tool.execute("call", { command: "echo hello", timeout: 999 }, undefined),
+    ).rejects.toThrow(/Main session policy blocked exec/);
+  });
+
+  it("blocks ssh command without policy config", async () => {
+    const tool = createMainSessionExecTool();
+    await expect(
+      tool.execute("call", { command: "ssh user@example.com", timeout: 10 }, undefined),
+    ).rejects.toThrow(/blocked SSH command/);
+  });
+
+  it("allows short background-safe exec", async () => {
+    const tool = createMainSessionExecTool();
+    const res = await tool.execute("call", { command: "echo ok", timeout: 10, yieldMs: 1000 }, undefined);
+    expect(String((res.details as { stdout?: string }).stdout ?? "")).toContain("ok");
+  });
+});
