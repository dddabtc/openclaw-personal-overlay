From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: zhaod <zhaod@local>
Date: Mon, 2 Mar 2026 08:58:00 -0400
Subject: [PATCH 21/21] feat(agents): default sub-session timeout to 6 hours

Set the default agent timeout from 600s to 21600s and align sessions_spawn
fallback runTimeoutSeconds to 21600 when config is absent.

---
 src/agents/subagent-spawn.ts | 6 +++---
 src/agents/timeout.ts        | 2 +-
 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/src/agents/subagent-spawn.ts b/src/agents/subagent-spawn.ts
index 7f6ec8bfc7672fb95be965b676c3fd1249f9cb84..4ec80ec8e6473f9d7f8efb13056d012b91cfacb0 100644
--- a/src/agents/subagent-spawn.ts
+++ b/src/agents/subagent-spawn.ts
@@ -196,13 +196,13 @@ export async function spawnSubagentFromToolParams(
 
   // When agent omits runTimeoutSeconds, use the config default.
-  // Falls back to 0 (no timeout) if config key is also unset,
-  // preserving current behavior for existing deployments.
+  // Falls back to 21600 (6 hours) if config key is also unset.
   const cfgSubagentTimeout =
     typeof cfg?.agents?.defaults?.subagents?.runTimeoutSeconds === "number" &&
     Number.isFinite(cfg.agents.defaults.subagents.runTimeoutSeconds)
       ? Math.max(0, Math.floor(cfg.agents.defaults.subagents.runTimeoutSeconds))
-      : 0;
+      : 21600;
   const runTimeoutSeconds =
     typeof params.runTimeoutSeconds === "number" && Number.isFinite(params.runTimeoutSeconds)
       ? Math.max(0, Math.floor(params.runTimeoutSeconds))
diff --git a/src/agents/timeout.ts b/src/agents/timeout.ts
index 817fcd7eb087c8eb2f80d68d7de7e2fa4cc886dd..31df0baadf4504a844f627b95f6262506ff32956 100644
--- a/src/agents/timeout.ts
+++ b/src/agents/timeout.ts
@@ -1,6 +1,6 @@
 import type { OpenClawConfig } from "../config/config.js";
 
-const DEFAULT_AGENT_TIMEOUT_SECONDS = 600;
+const DEFAULT_AGENT_TIMEOUT_SECONDS = 21600;
 const MAX_SAFE_TIMEOUT_MS = 2_147_000_000;
 
 const normalizeNumber = (value: unknown): number | undefined =>
-- 
2.25.1
