From db65cf330cf3bd40a2d2de39fae68350843dc286 Mon Sep 17 00:00:00 2001
From: subagent-bot <subagent-bot@example.com>
Date: Sun, 8 Mar 2026 10:33:36 -0300
Subject: [PATCH 5/5] feat: slash commands bypass session queue (fast-path
 control)

- All control commands (/status, /model, /reasoning, /help, etc.) now bypass
  the Telegram sequentialize queue, allowing immediate execution
- Updated exec guard error messages to recommend sessions_spawn for long-running
  tasks instead of background mode
- SSH commands blocked with clearer guidance towards sub-sessions
- Sub-sessions have 6-hour default timeout, suitable for complex tasks
---
 src/agents/bash-tools.exec.ts      | 29 +++++++++++++++++++----------
 src/auto-reply/status.ts           |  2 +-
 src/cli/daemon-cli/status.print.ts |  2 +-
 src/telegram/sequential-key.ts     |  9 ++++++++-
 4 files changed, 29 insertions(+), 13 deletions(-)

diff --git a/src/agents/bash-tools.exec.ts b/src/agents/bash-tools.exec.ts
index 0420f005b..cc333be36 100644
--- a/src/agents/bash-tools.exec.ts
+++ b/src/agents/bash-tools.exec.ts
@@ -207,25 +207,33 @@ function enforceMainSessionPolicy(params: {
 }): void {
   const { command, sessionKey, policy, timeout, background, yieldMs } = params;
 
-  // Skip if not main session or no policy configured
-  if (!isMainAgentSession(sessionKey) || !policy) {
+  // Skip if not main session
+  if (!isMainAgentSession(sessionKey)) {
     return;
   }
 
+  // Default policy when none configured - enforce safety by default
+  const effectivePolicy: ExecMainSessionPolicy = policy ?? {
+    blockSshCommands: true,
+    forbidLongExec: true,
+    maxExecTimeoutSec: 30,
+    maxOutputBytes: 51200,
+  };
+
   // Check SSH block
-  if (policy.blockSshCommands && isSshCommand(command)) {
+  if (effectivePolicy.blockSshCommands && isSshCommand(command)) {
     throw new Error(
       [
         "Main session policy blocked SSH command.",
-        "SSH/SCP/SFTP commands must be executed through a sub-session.",
-        "Use sessions_spawn to run this command in an isolated session.",
+        "SSH/SCP/SFTP commands must run in a sub-session (default timeout: 6 hours).",
+        "Use sessions_spawn to delegate this task. The sub-session will auto-announce when done.",
       ].join("\n"),
     );
   }
 
   // Check long exec block
-  if (policy.forbidLongExec) {
-    const maxExecTimeoutSec = resolveMainSessionMaxExecTimeoutSec(policy);
+  if (effectivePolicy.forbidLongExec) {
+    const maxExecTimeoutSec = resolveMainSessionMaxExecTimeoutSec(effectivePolicy);
     const backgroundRequested = background === true;
     const yieldRequested = typeof yieldMs === "number";
     const yieldExceedsLimit = !yieldRequested || yieldMs > 120_000;
@@ -234,14 +242,15 @@ function enforceMainSessionPolicy(params: {
 
     const longExecByTimeout = timeoutMissingOrTooLarge;
     const longExecByForeground =
-      !backgroundRequested && (policy.requireBackgroundForExec || yieldExceedsLimit);
+      !backgroundRequested && (effectivePolicy.requireBackgroundForExec || yieldExceedsLimit);
 
     if (longExecByTimeout || longExecByForeground) {
       throw new Error(
         [
           `Main session policy blocked exec: command appears long-running.`,
-          `For main session, timeout must be <= ${maxExecTimeoutSec}s and long runs must use background=true.`,
-          "Use sessions_spawn for longer tasks, or set background=true with an appropriate timeout.",
+          `Main session exec timeout must be <= ${maxExecTimeoutSec}s to keep the session responsive.`,
+          "Use sessions_spawn to run this in a sub-session (default timeout: 6 hours).",
+          "The sub-session will auto-announce completion. Only use background=true for quick fire-and-forget tasks.",
         ].join("\n"),
       );
     }
